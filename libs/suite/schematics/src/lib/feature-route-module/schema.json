{
  "$schema": "https://json-schema.org/schema",
  "$id": "FeatureRouteModule",
  "title": "Feature module with route",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Enter the feature name",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use?"
    },
    "directory": {
      "type": "string",
      "description": "Entre de path to folder",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Indicate directory where would you like to add?"
    }
  },
  "required": ["name", "directory"]
}
